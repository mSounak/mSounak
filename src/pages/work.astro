---
import Base from "../layouts/Base.astro";

const roles = [
  {
    company: "Staple",
    url: "https://www.staple.io/",
    title: "Software Engineer",
    location: "Remote · Bengaluru",
    period: "Apr 2024 — present",
    bullets: [
      "Engineered a message-based system on RabbitMQ that became the backbone for high-volume document processing — improved reliability and unblocked horizontal scale.",
      "Designed and shipped an LLM-driven document detection system that lifted classification accuracy by 15% and reduced manual triage for clients.",
      "Built a credit-card detection model used to redact sensitive information across 510k client documents — a hard requirement for compliance and data privacy.",
      "Stabilized the platform through a backlog of critical bugfixes, lifting client uptime and reducing on-call noise.",
    ],
  },
  {
    company: "Pratilipi",
    url: "https://www.pratilipi.com/",
    title: "Data Scientist",
    location: "Bengaluru",
    period: "May 2022 — Apr 2024",
    bullets: [
      "Owned personalized recommendations: grew total reads 50% and subscriptions 4×.",
      "Cut ML deployment cost 70% by rebuilding the pipeline on Metaflow.",
      "Drove +150k daily reads through AWS Personalize campaigns.",
      "Improved recommender quality 20% via hyperparameter tuning.",
      "Built a Bi-LSTM gender prediction model with 93% F1 used downstream by ranking.",
      "Built a semantic search API (Sentence Transformers + FastAPI) that powered content discovery in Disney and Star deals.",
      "Stood up and maintained the internal ML platform on AWS + Jenkins; migrated existing workflows to Metaflow for reliability.",
      "Added observability with InfluxDB and Grafana; automated AWS ECS deployments with Terraform.",
    ],
  },
  {
    company: "Bobble.ai",
    url: "https://www.bobble.ai/",
    title: "AI Intern",
    location: "Remote",
    period: "Feb 2022 — May 2022",
    bullets: [
      "Wrote data-cleaning pipelines processing terabytes of conversational data.",
      "Ran intent recognition on a Hindi macaronic corpus.",
      "Built a brand-sentiment model over conversational text.",
      "Trained FastText on large datasets for sentence and word embeddings.",
      "Clustered large conversational datasets to surface usage patterns.",
    ],
  },
];

const skills = {
  Languages: ["Python", "Go", "C/C++", "SQL"],
  "Backend & infra": ["RabbitMQ", "Docker", "Kubernetes", "Terraform", "FastAPI", "Flask"],
  "AI / ML": ["LLMs", "MCP", "PyTorch", "TensorFlow", "Scikit-learn", "Sentence Transformers"],
  "Cloud & ops": ["AWS", "Metaflow", "MLflow", "Grafana", "InfluxDB", "Jenkins"],
};
---
<Base title="Work — Sounak" current="work">
  <h1>Work</h1>
  <p class="muted">A short timeline. For the full version, see my <a href="/SounakMukherjee-CV.pdf">CV</a>.</p>

  {roles.map((r) => (
    <section class="role">
      <header class="role-head">
        <div class="role-line">
          <a href={r.url} class="role-company">{r.company}</a>
          <span class="role-sep">·</span>
          <span class="role-title">{r.title}</span>
        </div>
        <div class="role-meta">
          <span>{r.period}</span>
          <span class="role-sep">·</span>
          <span>{r.location}</span>
        </div>
      </header>
      <ul class="role-bullets">
        {r.bullets.map((b) => <li>{b}</li>)}
      </ul>
    </section>
  ))}

  <hr />

  <h2>Stack</h2>
  <dl class="skills">
    {Object.entries(skills).map(([group, items]) => (
      <>
        <dt>{group}</dt>
        <dd>{items.join(" · ")}</dd>
      </>
    ))}
  </dl>

  <hr />

  <h2>Education</h2>
  <p>
    <strong>Kalinga Institute of Industrial Technology</strong>, Bhubaneswar &mdash;
    B.Tech, Computer Science &amp; Engineering. CGPA 9.15. 2019&ndash;2023.
  </p>
</Base>

<style>
  .role { margin: 2em 0; }
  .role-head { margin-bottom: 0.6em; }
  .role-line { font-size: 1rem; color: var(--bright); }
  .role-company { color: var(--accent); border-bottom: 0; }
  .role-company:hover { border-bottom: 1px solid var(--accent); }
  .role-sep { color: var(--subtle); margin: 0 0.5em; }
  .role-title { color: var(--fg); }
  .role-meta {
    color: var(--subtle);
    font-size: 0.82rem;
    margin-top: 0.1em;
  }
  .role-meta::before { content: "// "; }
  .role-bullets {
    list-style: none;
    padding-left: 0;
    margin: 0.6em 0 0;
  }
  .role-bullets li {
    position: relative;
    padding-left: 1.2em;
    margin: 0.45em 0;
    color: var(--fg);
  }
  .role-bullets li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .skills {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.4em 1.2em;
    margin: 1em 0;
  }
  .skills dt { color: var(--subtle); }
  .skills dt::before { content: "$ "; color: var(--accent); }
  .skills dd { margin: 0; color: var(--fg); }
</style>
