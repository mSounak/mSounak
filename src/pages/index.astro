---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latest = posts[0];
---
<Base title="Sounak Mukherjee" current="home">
  <h1><span class="cursor">Sounak Mukherjee</span></h1>

  <p>
    Hi &mdash; I&rsquo;m Sounak, a backend and infrastructure engineer based in Bangalore.
  </p>

  <p>
    I work at the intersection of <strong>applied AI and backend systems</strong> &mdash; currently building infrastructure
    at <a href="https://www.staple.io/">Staple</a>, where we extract structured data from invoices, contracts, and claims
    with cryptographic audit trails, so regulated teams can defend every figure to an auditor.
  </p>

  <p>
    Before that, <a href="https://www.pratilipi.com/">Pratilipi</a> &mdash; a self-publishing platform for stories in
    Indian languages &mdash; where I worked on the data science side.
  </p>

  <p>
    I&rsquo;m building the part of AI that doesn&rsquo;t get demoed: the agents, tools, memory layers, and pipelines
    that turn an impressive model into a system that quietly runs a business.
  </p>

  <p>
    See <a href="/about">/about</a> for the longer story, <a href="/posts">/posts</a> for writing,
    and <a href="/projects">/projects</a> for things I&rsquo;ve built.
  </p>

  {latest && (
    <>
      <hr />
      <p class="muted">Latest post</p>
      <p>
        <a href={`/posts/${latest.slug}/`}>{latest.data.title}</a><br />
        <span class="post-meta">{latest.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
      </p>
    </>
  )}
</Base>
