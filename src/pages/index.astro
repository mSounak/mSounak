---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latest = posts[0];
---
<Base title="Sounak Mukherjee" current="home">
  <h1><span class="cursor">Sounak Mukherjee</span></h1>

  <p>
    Hi, I&rsquo;m Sounak. I&rsquo;m a backend and infrastructure engineer at <a href="https://www.staple.ai/">Staple AI</a> &mdash;
    a document-intelligence company that turns invoices, forms, and contracts into structured data &mdash;
    based in Bengaluru. I work on the systems that move documents through scanning pipelines and into LLM-powered extraction.
  </p>

  <p>
    Before this, I was a data scientist at <a href="https://www.pratilipi.com/">Pratilipi</a>,
    a self-publishing platform for stories in Indian languages.
  </p>

  {latest && (
    <>
      <hr />
      <p class="muted">Latest writing</p>
      <p>
        <a href={`/writing/${latest.slug}/`}>{latest.data.title}</a><br />
        <span class="post-meta">{latest.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
      </p>
    </>
  )}
</Base>
