</Base>

<style>
  .role {
    margin: 2em 0;
    padding-left: 14px;
    border-left: 1px solid var(--rule);
  }
  .role-head {
    margin-bottom: 0.4em;
    font-size: 1rem;
    line-height: 1.5;
    flex-wrap: wrap;
  }
  .role-company {
    color: var(--accent);
    font-weight: 500;
    border-bottom: 0;
  }
  .role-company:hover {
    border-bottom: 1px solid var(--accent);
  }
  .role-title { color: var(--bright); }
  .role-period {
    color: var(--subtle);
    font-style: italic;
  }
  .role-sep {
    color: var(--subtle);
    margin: 0 6px;
  }
  .role-summary {
    margin: 0.4em 0 0.6em;
    color: var(--muted);
  }
  .role-bullets {
    list-style: none;
    padding-left: 0;
    margin: 0.4em 0 0;
  }
  .role-bullets li {
    position: relative;
    padding-left: 1.2em;
    margin: 0.35em 0;
    color: var(--fg);
  }
  .role-bullets li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .elsewhere {
    list-style: none;
    padding-left: 0;
  }
  .elsewhere li {
    margin: 0.4em 0;
    color: var(--muted);
  }
  .elsewhere li::before {
    content: "› ";
    color: var(--accent);
  }
</style>
